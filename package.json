{
  "name": "vue-apexgantt",
  "version": "1.1.0",
  "description": "Vue 3 wrapper for ApexGantt - Interactive Gantt chart library",
  "type": "module",
  "main": "./dist/vue-apexgantt.umd.js",
  "module": "./dist/vue-apexgantt.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-apexgantt.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-apexgantt.umd.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "apexgantt": ">=3.10.2",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "apexgantt": "^3.10.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "gantt",
    "gantt-chart",
    "apexgantt",
    "timeline",
    "project-management"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/apexcharts/vue-apexgantt.git"
  }
}
